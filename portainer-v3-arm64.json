			"webpage": "https://mariadb.org/",
			"id": 116,
			"note": "<h4>Official Webpage: <a href=\"https://mariadb.org/\" target=\"_blank\">https://mariadb.org</a></h4><h4>Official Docker Documentation: <a href=\"https://docs.linuxserver.io/images/docker-mariadb\" target=\"_blank\">https://docs.linuxserver.io/images/docker-mariadb</a></h4>"
		},
		{
			"categories": [
				"Monitor",
				"Tools"
			],
			"description": "Monitor your Raspberry Pi and Dockers using Grafana developed by oijkn.",
			"env": [
				{
					"default": "1y",
					"label": "Retention time",
					"name": "PROM_RETENTION_TIME"
				},
				{
					"default": "10GB",
					"label": "Retention size",
					"name": "PROM_RETENTION_SIZE"
				},
				{
					"default": "admin",
					"label": "Grafana user",
					"name": "GF_SECURITY_ADMIN_USER"
				},
				{
					"default": "admin",
					"label": "Grafana password",
					"name": "GF_SECURITY_ADMIN_PASSWORD"
				}
			],
			"logo": "https://raw.githubusercontent.com/CircuitGremlin/pi-hosted/master/images/rpi_monitor.png",
			"name": "raspberrypi-docker-monitor",
			"officialDoc": "https://github.com/CircuitGremlin/pi-hosted/blob/master/docs/rpi_docker_monitor.md",
			"piHostedDoc": "rpi_docker_monitor.md",
			"platform": "linux",
			"ports": [
				"3000:3000/tcp"
			],
			"preInstallScript": "rpi_docker_monitor.sh",
			"repository": {
				"stackfile": "stack/raspberrypi-monitoring.yml",
				"url": "https://github.com/CircuitGremlin/pi-hosted"
			},
			"restart_policy": "unless-stopped",
			"title": "Raspberry Pi Docker Monitor",
			"type": 3,
			"webpage": "https://github.com/CircuitGremlin/pi-hosted/blob/master/docs/rpi_docker_monitor.md",
			"id": 179,
			"note": "<h4>Original repository from oijkn: <a href=\"https://github.com/oijkn/Docker-Raspberry-PI-Monitoring\" target=\"_blank\">https://github.com/oijkn/Docker-Raspberry-PI-Monitoring</a></h4><h4>Pi-Hosted dedicated documentation: <a href=\"https://github.com/CircuitGremlin/pi-hosted/blob/master/docs/rpi_docker_monitor.md\" target=\"_blank\">rpi_docker_monitor.md</a></h4><h4><a href=\"https://github.com/CircuitGremlin/pi-hosted/blob/master/tools/rpi_docker_monitor.sh\" target=\"_blank\">Pre-installation script</a> must be RAN before you install:<br>wget -qO- https://raw.githubusercontent.com/CircuitGremlin/pi-hosted/master/tools/rpi_docker_monitor.sh | bash</h4>"
		}
	]
