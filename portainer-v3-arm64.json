{
	"version": "3",
	"templates": [
		{
			"categories": [
				"Other",
				"Tools"
			],
			"description": "A dead simple static HOMepage for your servER to keep your services on hand, from a simple yaml configuration file.",
			"env": [
				{
					"default": "1000",
					"label": "GID",
					"name": "GID"
				},
				{
					"default": "1000",
					"label": "UID",
					"name": "UID"
				}
			],
			"image": "b4bz/homer:latest",
			"logo": "https://raw.githubusercontent.com/CircuitGremlin/pi-hosted/master/images/homer.png",
			"name": "homer",
			"note": "<h4>Official Webpage: <a href=\"https://github.com/bastienwirtz/homer\" target=\"_blank\">https://github.com/bastienwirtz/homer</a></h4><h4>Official Docker Documentation: <a href=\"https://github.com/bastienwirtz/homer/blob/main/docs/configuration.md\" target=\"_blank\">https://github.com/bastienwirtz/homer/blob/main/docs/configuration.md</a></h4><h4><a href=\"https://github.com/CircuitGremlin/pi-hosted/blob/master/tools/install_homer.sh\" target=\"_blank\">Pre-installation script</a> must be RAN before you install:<br>wget -qO- https://raw.githubusercontent.com/CircuitGremlin/pi-hosted/master/tools/install_homer.sh | bash</h4><h4>This container requires a yml file within the config volume. See the documentation.</h4>",
			"platform": "linux",
			"ports": [
				"8902:8080/tcp"
			],
			"network": "bridge",
			"restart_policy": "unless-stopped",
			"title": "Homer",
			"type": 1,
			"volumes": [
				{
					"bind": "/portainer/Files/AppData/Config/Homer/assets",
					"container": "/www/assets"
				}
			],
			"webpage": "https://github.com/bastienwirtz/homer"
		},
		{
			"categories": [
				"Other",
				"Tools"
			],
			"description": "InfluxDB is an open source time series database for recording metrics, events, and analytics.",
			"env": [
				{
					"default": "setup",
					"label": "Initial mode",
					"name": "DOCKER_INFLUXDB_INIT_MODE"
				},
				{
					"default": "",
					"label": "Initial username",
					"name": "DOCKER_INFLUXDB_INIT_USERNAME"
				},
				{
					"default": "",
					"label": "Initial password",
					"name": "DOCKER_INFLUXDB_INIT_PASSWORD"
				},
				{
					"default": "",
					"label": "Initial organisation",
					"name": "DOCKER_INFLUXDB_INIT_ORG"
				},
				{
					"default": "",
					"label": "Initial bucket",
					"name": "DOCKER_INFLUXDB_INIT_BUCKET"
				}
			],
			"image": "influxdb:2",
			"logo": "https://raw.githubusercontent.com/docker-library/docs/43d87118415bb75d7bb107683e79cd6d69186f67/influxdb/logo.png",
			"name": "influxdb2",
			"note": "<h4>Official Webpage: <a href=\"https://www.influxdata.com/\" target=\"_blank\">https://www.influxdata.com/</a></h4><h4>Official Docker Documentation: <a href=\"https://docs.influxdata.com/influxdb/v2/install/use-docker-compose\" target=\"_blank\">https://docs.influxdata.com/influxdb/v2/install/use-docker-compose</a></h4><h4>Set your initial organisation, bucket, username and password below. Wisit Web UI at http://your_host:8086/ for setting up a tocken.</h4>",
			"platform": "linux",
			"ports": [
				"8086:8086/tcp"
			],
			"restart_policy": "unless-stopped",
			"title": "Influxdb 2",
			"type": 1,
			"volumes": [
				{
					"bind": "/portainer/Files/AppData/Config/Influxdb2/data",
					"container": "/var/lib/influxdb2"
				},
				{
					"bind": "/portainer/Files/AppData/Config/Influxdb2/config",
					"container": "/etc/influxdb2"
				}
			]
		},
		{
			"categories": [
				"Databases",
				"Tools"
			],
			"description": "An Enhanced drop in replacement for Mysql",
			"env": [
				{
					"default": "1000",
					"label": "PUID",
					"name": "PUID"
				},
				{
					"default": "1000",
					"label": "PGID",
					"name": "PGID"
				},
				{
					"default": "",
					"label": "MySQL root password",
					"name": "MYSQL_ROOT_PASSWORD"
				},
				{
					"default": "",
					"label": "MySQL database",
					"name": "MYSQL_DATABASE"
				},
				{
					"default": "",
					"label": "MySQL user",
					"name": "MYSQL_USER"
				},
				{
					"default": "",
					"label": "MySQL password",
					"name": "MYSQL_PASSWORD"
				}
			],
			"image": "linuxserver/mariadb:arm64v8-latest",
			"logo": "https://raw.githubusercontent.com/CircuitGremlin/pi-hosted/master/images/mariadb.png",
			"name": "mariadb",
			"platform": "linux",
			"ports": [
				"3306:3306/tcp"
			],
			"network": "bridge",
			"restart_policy": "unless-stopped",
			"title": "MariaDB",
			"type": 1,
			"volumes": [
				{
					"bind": "/portainer/Files/AppData/Config/Mariadb",
					"container": "/config"
				}
			],
			"note": "<h4>Official Webpage: <a href=\"https://mariadb.org/\" target=\"_blank\">https://mariadb.org</a></h4><h4>Official Docker Documentation: <a href=\"https://docs.linuxserver.io/images/docker-mariadb\" target=\"_blank\">https://docs.linuxserver.io/images/docker-mariadb</a></h4>"
		},
		{
			"categories": [
				"Monitor",
				"Tools"
			],
			"description": "Monitor your Raspberry Pi and Dockers using Grafana developed by oijkn.",
			"env": [
				{
					"default": "1y",
					"label": "Retention time",
					"name": "PROM_RETENTION_TIME"
				},
				{
					"default": "10GB",
					"label": "Retention size",
					"name": "PROM_RETENTION_SIZE"
				},
				{
					"default": "admin",
					"label": "Grafana user",
					"name": "GF_SECURITY_ADMIN_USER"
				},
				{
					"default": "admin",
					"label": "Grafana password",
					"name": "GF_SECURITY_ADMIN_PASSWORD"
				}
			],
			"logo": "https://raw.githubusercontent.com/CircuitGremlin/pi-hosted/master/images/rpi_monitor.png",
			"name": "raspberrypi-docker-monitor",
			"platform": "linux",
			"ports": [
				"3000:3000/tcp"
			],
			"repository": {
				"stackfile": "stack/raspberrypi-monitoring.yml",
				"url": "https://github.com/CircuitGremlin/pi-hosted"
			},
			"restart_policy": "unless-stopped",
			"title": "Raspberry Pi Docker Monitor",
			"type": 3,
			"note": "<h4>Original repository from oijkn: <a href=\"https://github.com/oijkn/Docker-Raspberry-PI-Monitoring\" target=\"_blank\">https://github.com/oijkn/Docker-Raspberry-PI-Monitoring</a></h4><h4>Pi-Hosted dedicated documentation: <a href=\"https://github.com/CircuitGremlin/pi-hosted/blob/master/docs/rpi_docker_monitor.md\" target=\"_blank\">rpi_docker_monitor.md</a></h4><h4><a href=\"https://github.com/CircuitGremlin/pi-hosted/blob/master/tools/rpi_docker_monitor.sh\" target=\"_blank\">Pre-installation script</a> must be RAN before you install:<br>wget -qO- https://raw.githubusercontent.com/CircuitGremlin/pi-hosted/master/tools/rpi_docker_monitor.sh | bash</h4>"
		},
		{
			"categories": [
				"Other",
				"Tools"
			],
			"description": "Snippet Box is a simple self-hosted app for organizing your code snippets.",
			"image": "pawelmalak/snippet-box:arm",
			"logo": "https://raw.githubusercontent.com/CircuitGremlin/pi-hosted/master/images/snibox.png",
			"name": "Snippet-box",
			"note": "<h4>Official Webpage: <a href=\"https://github.com/pawelmalak/snippet-box\" target=\"_blank\">https://github.com/pawelmalak/snippet-box</a></h4><h4>Official Docker Documentation: <a href=\"https://github.com/pawelmalak/snippet-box#with-docker\" target=\"_blank\">https://github.com/pawelmalak/snippet-box#with-docker</a></h4>",
			"platform": "linux",
			"ports": [
				"5010:5000/tcp"
			],
			"network": "bridge",
			"restart_policy": "unless-stopped",
			"title": "Snippet-box",
			"type": 1,
			"volumes": [
				{
					"bind": "/portainer/Files/AppData/Config/Snippet-box",
					"container": "/app/data"
				}
			]
		}
	]
}