					"label": "PUID",
					"name": "PUID"
				},
				{
					"default": "1000",
					"label": "PGID",
					"name": "PGID"
				},
				{
					"default": "",
					"label": "MySQL root password",
					"name": "MYSQL_ROOT_PASSWORD"
				},
				{
					"default": "",
					"label": "MySQL database",
					"name": "MYSQL_DATABASE"
				},
				{
					"default": "",
